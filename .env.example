# GitHub Pages Configuration
# For user/org site: PUBLIC_SITE_URL=https://username.github.io
# For project site: PUBLIC_SITE_URL=https://username.github.io
PUBLIC_SITE_URL=https://username.github.io

# For project site, set the repository name
# For user/org site, leave empty or remove
PUBLIC_BASE_PATH=/email-lab

# GitHub Info
GITHUB_USERNAME=your-username
GITHUB_REPOSITORY=email-lab
