---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Open Positions" description="Join the EMAIL Lab - open positions for graduate students, postdocs, and undergraduate researchers.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Open Positions</h1>
      <p class="section-subtitle">Join {siteConfig.abbreviation} at {siteConfig.university}</p>

      <div class="openings-intro">
        <p>
          We are always looking for motivated and talented individuals to join our team.
          If you are interested in environmental monitoring, numerical modeling,
          and artificial intelligence, we encourage you to apply.
        </p>
      </div>

      <div class="positions-grid">
        <article class="card position-card">
          <div class="position-badge">Open</div>
          <h3>Ph.D. Student</h3>
          <p class="position-ko">박사과정</p>
          <p class="position-desc">
            We are seeking Ph.D. candidates with strong backgrounds in environmental engineering,
            computer science, or related fields. Research topics include water quality modeling,
            AI-based environmental prediction, and remote sensing applications.
          </p>
          <div class="position-topics">
            <h4>Possible Research Topics</h4>
            <ul>
              <li>AI-driven water quality and HAB prediction</li>
              <li>Graph neural networks for environmental systems</li>
              <li>Digital twin for water infrastructure</li>
              <li>Explainable AI for environmental decision support</li>
            </ul>
          </div>
        </article>

        <article class="card position-card">
          <div class="position-badge">Open</div>
          <h3>M.S. Student</h3>
          <p class="position-ko">석사과정</p>
          <p class="position-desc">
            M.S. positions are available for students interested in applying machine learning
            and deep learning methods to environmental engineering problems.
          </p>
          <div class="position-topics">
            <h4>Possible Research Topics</h4>
            <ul>
              <li>Deep learning for water quality simulation</li>
              <li>Hydrological modeling with AI</li>
              <li>Environmental data analysis and visualization</li>
            </ul>
          </div>
        </article>

        <article class="card position-card">
          <div class="position-badge">Open</div>
          <h3>Integrated M.S.–Ph.D. Student</h3>
          <p class="position-ko">석박사통합과정</p>
          <p class="position-desc">
            Combined M.S.–Ph.D. positions are available for students who wish to pursue
            an integrated graduate program.
          </p>
        </article>

        <article class="card position-card">
          <div class="position-badge">Open</div>
          <h3>Undergraduate Research Intern</h3>
          <p class="position-ko">학부연구원</p>
          <p class="position-desc">
            Undergraduate students from diverse backgrounds are welcome to gain research
            experience in our lab. We provide mentorship and hands-on training in
            environmental modeling and AI.
          </p>
        </article>

        <article class="card position-card">
          <h3>Postdoctoral Researcher</h3>
          <p class="position-ko">박사후연구원</p>
          <p class="position-desc">
            Postdoctoral positions may be available depending on funded projects.
            Please contact us for current availability.
          </p>
        </article>
      </div>

      <div class="apply-section">
        <h2>How to Apply</h2>
        <div class="apply-content">
          <p>
            Interested candidates should send a <strong>Curriculum Vitae (CV)</strong> to:
          </p>
          <a href={`mailto:${siteConfig.email}`} class="btn btn-primary apply-btn">
            {siteConfig.email}
          </a>
          <p class="apply-note">
            Please include your academic background, research interests, and any relevant
            publications or projects. Applications from diverse academic backgrounds are
            welcome.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .openings-intro {
    max-width: 700px;
    font-size: var(--text-lg);
    color: var(--color-text-light);
    margin-bottom: var(--space-8);
  }

  .positions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-12);
  }

  .position-card {
    position: relative;
  }

  .position-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
    padding-right: 60px;
  }

  .position-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .position-desc {
    color: var(--color-text-light);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .position-badge {
    position: absolute;
    top: var(--space-6);
    right: var(--space-6);
    padding: 2px 10px;
    background: #e8f5e9;
    color: var(--color-secondary);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .position-topics h4 {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .position-topics ul {
    padding-left: var(--space-6);
  }

  .position-topics li {
    list-style: disc;
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-1);
  }

  .apply-section {
    background: var(--color-bg-alt);
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .apply-section h2 {
    margin-bottom: var(--space-4);
  }

  .apply-content p {
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
  }

  .apply-btn {
    font-size: var(--text-lg);
    padding: var(--space-4) var(--space-8);
    margin-bottom: var(--space-4);
  }

  .apply-note {
    font-size: var(--text-sm);
    max-width: 500px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .positions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
