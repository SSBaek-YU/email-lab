---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
import { patents } from '../data/patents';

const ongoing = projects.filter((p) => p.status === 'ongoing');
const completed = projects.filter((p) => p.status === 'completed');
---

<BaseLayout title="Projects & Patents" description="Research projects, patents, and software registrations from the EMAIL Lab.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Projects</h1>
      <p class="section-subtitle">Funded research projects</p>

      {ongoing.length > 0 && (
        <div class="project-section">
          <h2>Ongoing Projects</h2>
          <div class="project-list">
            {ongoing.map((project) => (
              <article class="card project-card">
                <div class="project-status ongoing">Ongoing</div>
                <h3>{project.title}</h3>
                <p class="project-title-ko">{project.titleKo}</p>
                <p class="project-summary">{project.summary}</p>
                <div class="project-meta">
                  <span><strong>Funding:</strong> {project.fundingAgency}</span>
                  <span><strong>Period:</strong> {project.period}</span>
                  <span><strong>Role:</strong> {project.role}</span>
                </div>
                {!project.verified && (
                  <p class="verify-note">* Details need verification</p>
                )}
              </article>
            ))}
          </div>
        </div>
      )}

      {completed.length > 0 && (
        <div class="project-section">
          <h2>Completed Projects</h2>
          <div class="project-list">
            {completed.map((project) => (
              <article class="card project-card">
                <div class="project-status completed">Completed</div>
                <h3>{project.title}</h3>
                <p class="project-summary">{project.summary}</p>
                <div class="project-meta">
                  <span><strong>Period:</strong> {project.period}</span>
                </div>
              </article>
            ))}
          </div>
        </div>
      )}

      <!-- Patents & Software -->
      <div class="project-section">
        <h2>Patents & Software Registrations</h2>
        <div class="patent-list">
          {patents.map((patent) => (
            <div class="patent-item">
              <span class="patent-year">{patent.year}</span>
              <div class="patent-content">
                <span class="patent-type">{patent.type === 'patent' ? 'Patent' : 'Software'}</span>
                <h4>{patent.title}</h4>
                <p class="patent-reg">Registration No. {patent.registrationNumber}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .project-section {
    margin-bottom: var(--space-12);
  }

  .project-section h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-primary-bg);
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .project-card {
    position: relative;
  }

  .project-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
    padding-right: 80px;
  }

  .project-title-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .project-summary {
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
  }

  .project-status {
    position: absolute;
    top: var(--space-6);
    right: var(--space-6);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .project-status.ongoing {
    background: #e8f5e9;
    color: var(--color-secondary);
  }

  .project-status.completed {
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
  }

  .project-meta {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  .verify-note {
    font-size: var(--text-xs);
    color: var(--color-warning);
    margin-top: var(--space-3);
    font-style: italic;
  }

  .patent-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .patent-item {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
  }

  .patent-year {
    font-weight: 700;
    color: var(--color-primary);
    min-width: 50px;
  }

  .patent-type {
    display: inline-block;
    padding: 1px 8px;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }

  .patent-content h4 {
    font-size: var(--text-base);
    margin-bottom: var(--space-1);
  }

  .patent-reg {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
