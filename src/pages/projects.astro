---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';

const ongoing = projects.filter((p) => p.status === 'ongoing');
const completed = projects.filter((p) => p.status === 'completed');
---

<BaseLayout title="Projects" description="Ongoing and completed research projects from the EMAIL Lab.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Projects</h1>
      <p class="section-subtitle">Funded research projects</p>

      {ongoing.length > 0 && (
        <div class="project-section">
          <h2>Ongoing Projects <span class="title-ko">진행 중인 프로젝트</span></h2>
          <div class="project-list">
            {ongoing.map((project) => (
              <article class="card project-card">
                <div class="project-status ongoing">Ongoing</div>
                <h3>{project.title}</h3>
                <p class="project-title-ko">{project.titleKo}</p>
                {project.summary && <p class="project-summary">{project.summary}</p>}
                <div class="project-meta">
                  <span><strong>Funding:</strong> {project.fundingAgency}</span>
                  <span><strong>Period:</strong> {project.period}</span>
                  {project.role && <span><strong>Role:</strong> {project.role}</span>}
                </div>
              </article>
            ))}
          </div>
        </div>
      )}

      {completed.length > 0 && (
        <div class="project-section">
          <h2>Completed Projects <span class="title-ko">종료된 프로젝트</span></h2>
          <div class="project-list">
            {completed.map((project) => (
              <article class="card project-card">
                <div class="project-status completed">Completed</div>
                <h3>{project.title}</h3>
                <p class="project-title-ko">{project.titleKo}</p>
                {project.summary && <p class="project-summary">{project.summary}</p>}
                <div class="project-meta">
                  <span><strong>Funding:</strong> {project.fundingAgency}</span>
                  <span><strong>Period:</strong> {project.period}</span>
                </div>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .project-section {
    margin-bottom: var(--space-12);
  }

  .project-section h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-primary-bg);
  }

  .title-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .project-card {
    position: relative;
  }

  .project-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
    padding-right: 80px;
  }

  .project-title-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .project-summary {
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
  }

  .project-status {
    position: absolute;
    top: var(--space-6);
    right: var(--space-6);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .project-status.ongoing {
    background: var(--color-secondary-bg);
    color: var(--color-secondary);
  }

  .project-status.completed {
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
  }

  .project-meta {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }
</style>
