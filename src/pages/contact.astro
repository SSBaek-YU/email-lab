---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
---

<BaseLayout title="Contact" description="Contact the EMAIL Lab at Yeungnam University.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Contact</h1>
      <p class="section-subtitle">Get in touch with {siteConfig.abbreviation}</p>

      <div class="contact-grid">
        <div class="contact-info">
          <div class="contact-card">
            <h3>{siteConfig.labName}</h3>
            <p class="contact-ko">{siteConfig.labNameKo}</p>
          </div>

          <div class="contact-card">
            <h4>Address</h4>
            <!-- TODO: VERIFY CURRENT OFFICE -->
            <p>{siteConfig.address}</p>
            <p class="contact-ko">{siteConfig.addressKo}</p>
          </div>

          <div class="contact-card">
            <h4>Email</h4>
            <a href={`mailto:${siteConfig.email}`} class="contact-link">
              {siteConfig.email}
            </a>
          </div>

          <div class="contact-card">
            <h4>Phone</h4>
            <a href={`tel:${siteConfig.phone}`} class="contact-link">
              {siteConfig.phone}
            </a>
          </div>

          <div class="contact-card">
            <h4>Professor</h4>
            <p>
              Prof. {siteConfig.professorName} ({siteConfig.professorNameKo})<br />
              {siteConfig.professorTitle}<br />
              {siteConfig.department}
            </p>
          </div>

          <div class="contact-links">
            <a
              href={siteConfig.scholarUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline"
            >
              Google Scholar
            </a>
            <a
              href={siteConfig.universityUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline"
            >
              {siteConfig.university}
            </a>
            <a
              href={siteConfig.departmentUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline"
            >
              {siteConfig.department}
            </a>
          </div>
        </div>

        <div class="contact-map">
          <div class="map-container">
            <a
              href={siteConfig.mapUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="map-link"
            >
              <div class="map-placeholder">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <p>View on Google Maps</p>
                <p class="map-addr">{siteConfig.university}</p>
                <p class="map-addr">Building {siteConfig.building}, Room {siteConfig.room}</p>
              </div>
            </a>
          </div>

          <div class="directions">
            <h4>Getting Here</h4>
            <p>
              Yeungnam University is located in Gyeongsan, Gyeongsangbuk-do, South Korea.
              The campus is accessible by Gyeongsan city bus and is near
              Yeungnam University Station on the Daegu Metro Line 2.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  .contact-card {
    margin-bottom: var(--space-6);
  }

  .contact-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
  }

  .contact-card h4 {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: var(--space-2);
  }

  .contact-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }

  .contact-link {
    font-size: var(--text-lg);
    font-weight: 600;
  }

  .contact-links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-6);
  }

  .map-container {
    margin-bottom: var(--space-6);
  }

  .map-link {
    display: block;
    text-decoration: none;
    color: var(--color-text);
  }

  .map-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
    transition: all var(--transition);
  }

  .map-placeholder:hover {
    background: var(--color-primary-bg);
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .map-placeholder p {
    font-weight: 600;
  }

  .map-addr {
    font-size: var(--text-sm);
    font-weight: 400 !important;
    color: var(--color-text-light);
  }

  .directions h4 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .directions p {
    color: var(--color-text-light);
    font-size: var(--text-sm);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
