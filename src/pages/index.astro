---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
import { researchAreas } from '../data/research';
import { publications } from '../data/publications';
import { getCurrentMembers, getPIInfo } from '../data/people';

const base = import.meta.env.BASE_URL;
const latestPubs = publications.slice(0, 5);
const featuredResearch = researchAreas.slice(0, 4);
const members = getCurrentMembers().slice(0, 6);
const pi = getPIInfo();
---

<BaseLayout
  title="Home"
  description="EMAIL Lab - Environmental Monitoring/Modelling and AI Lab at Yeungnam University. Advancing environmental monitoring and modeling through artificial intelligence."
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-content">
      <p class="hero-dept">{siteConfig.department}, {siteConfig.university}</p>
      <h1 class="hero-title">{siteConfig.labName}</h1>
      <p class="hero-title-ko">{siteConfig.labNameKo}</p>
      <p class="hero-slogan">&ldquo;{siteConfig.slogan}&rdquo;</p>
      <p class="hero-desc">{siteConfig.sloganFormal}</p>
      <div class="hero-actions">
        <a href={`${base}research/`} class="btn btn-primary">Our Research</a>
        <a href={`${base}publications/`} class="btn btn-outline btn-outline-white">Publications</a>
        <a
          href={siteConfig.scholarUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline btn-outline-white"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 9a8 8 0 0 1 7.162 4.44L24 9.5z"/>
          </svg>
          Google Scholar
        </a>
      </div>
    </div>
  </section>

  <!-- Research Areas -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Research Areas</h2>
      <p class="section-subtitle">Bridging environmental science with artificial intelligence</p>
      <div class="grid grid-2 research-grid">
        {featuredResearch.map((area) => (
          <a href={`${base}research/`} class="card research-card">
            <h3>{area.title}</h3>
            <p class="research-card-ko">{area.titleKo}</p>
            <p class="research-card-desc">{area.description}</p>
            <div class="research-card-tags">
              {area.keywords.slice(0, 3).map((kw) => (
                <span class="tag">{kw}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
      <div class="section-cta">
        <a href={`${base}research/`} class="btn btn-outline">View All Research Areas</a>
      </div>
    </div>
  </section>

  <!-- Latest Publications -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Recent Publications</h2>
      <p class="section-subtitle">Latest research from {siteConfig.abbreviation}</p>
      <div class="pub-list">
        {latestPubs.map((pub) => (
          <article class="pub-item">
            <span class="pub-year">{pub.year}</span>
            <div class="pub-content">
              <h4 class="pub-title">{pub.title}</h4>
              <p class="pub-meta">{pub.authors}</p>
              <p class="pub-journal">
                <em>{pub.journal}</em>
                {pub.volume && `, ${pub.volume}`}
                {pub.articleNumber && `, ${pub.articleNumber}`}
              </p>
              {pub.doi && (
                <a
                  href={`https://doi.org/${pub.doi}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="pub-doi"
                >
                  DOI
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
      <div class="section-cta">
        <a href={`${base}publications/`} class="btn btn-primary">All Publications</a>
        <a href={siteConfig.scholarUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
          Google Scholar Profile
        </a>
      </div>
    </div>
  </section>

  <!-- People -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Our Team</h2>
      <p class="section-subtitle">Meet the members of {siteConfig.abbreviation}</p>
      <div class="grid grid-3 people-grid">
        {members.map((member) => (
          <div class="card people-card">
            <div class="people-avatar" aria-hidden="true">
              {member.name.charAt(0)}
            </div>
            <h4>{member.name}</h4>
            {member.nameKo && <p class="people-name-ko">{member.nameKo}</p>}
            <p class="people-role">{member.roleLabel}</p>
          </div>
        ))}
      </div>
      <div class="section-cta">
        <a href={`${base}people/`} class="btn btn-outline">All Members</a>
      </div>
    </div>
  </section>

  <!-- Open Positions CTA -->
  <section class="section section-cta-banner">
    <div class="container cta-inner">
      <h2>Join Our Lab</h2>
      <p>We are actively recruiting motivated students and researchers at all levels.</p>
      <div class="hero-actions">
        <a href={`${base}openings/`} class="btn btn-primary">Open Positions</a>
        <a href={`mailto:${siteConfig.email}`} class="btn btn-outline btn-outline-white">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 50%, var(--color-accent) 100%);
    color: white;
    padding: var(--space-20) 0 var(--space-16);
    text-align: center;
  }

  .hero-dept {
    font-size: var(--text-sm);
    opacity: 0.8;
    margin-bottom: var(--space-4);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .hero-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: white;
    margin-bottom: var(--space-2);
    line-height: 1.2;
  }

  .hero-title-ko {
    font-size: var(--text-lg);
    opacity: 0.7;
    margin-bottom: var(--space-6);
  }

  .hero-slogan {
    font-size: var(--text-xl);
    font-weight: 600;
    font-style: italic;
    margin-bottom: var(--space-2);
    opacity: 0.95;
  }

  .hero-desc {
    font-size: var(--text-base);
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto var(--space-8);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-outline-white {
    border-color: rgba(255, 255, 255, 0.6);
    color: white;
  }

  .btn-outline-white:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: white;
    color: white;
  }

  /* Research Cards */
  .research-card {
    text-decoration: none;
    color: var(--color-text);
  }

  .research-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }

  .research-card-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .research-card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .research-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* Publications */
  .pub-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .pub-item {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--color-bg-card);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-light);
  }

  .pub-year {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-primary);
    min-width: 50px;
    padding-top: 2px;
  }

  .pub-title {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-1);
    line-height: 1.4;
  }

  .pub-meta {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-1);
  }

  .pub-journal {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .pub-doi {
    font-size: var(--text-xs);
    padding: 2px 8px;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    border-radius: var(--radius-sm);
    font-weight: 600;
  }

  /* People */
  .people-card {
    text-align: center;
    padding: var(--space-8) var(--space-4);
  }

  .people-avatar {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-full);
    background: var(--color-primary-bg);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-2xl);
    font-weight: 700;
    margin: 0 auto var(--space-4);
  }

  .people-card h4 {
    font-size: var(--text-base);
    margin-bottom: var(--space-1);
  }

  .people-name-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .people-role {
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  /* CTA Banner */
  .section-cta-banner {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    color: white;
    text-align: center;
    padding: var(--space-12) 0;
  }

  .section-cta-banner h2 {
    color: white;
    margin-bottom: var(--space-3);
  }

  .section-cta-banner p {
    opacity: 0.9;
    margin-bottom: var(--space-6);
    font-size: var(--text-lg);
  }

  .section-cta {
    text-align: center;
    margin-top: var(--space-8);
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-12) 0 var(--space-8);
    }

    .pub-item {
      flex-direction: column;
      gap: var(--space-2);
    }

    .research-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
