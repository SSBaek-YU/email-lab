---
import BaseLayout from '../layouts/BaseLayout.astro';
import { galleryEvents } from '../data/gallery';

const base = (import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/');
const withBase = (p: string) => `${base}${p.replace(/^\//, '')}`;

const sortedEvents = [...galleryEvents]
  .filter((e) => e.images.length > 0)
  .sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout title="Gallery" description="Photos from EMAIL Lab events, conferences, and activities.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Gallery</h1>
      <p class="section-subtitle">Memories from our lab activities</p>

      <div class="gallery-grid">
        {sortedEvents.map((event) => {
          const thumb = event.images[event.thumbnailIndex] ?? event.images[0];
          const imagesJson = JSON.stringify(event.images.map(withBase));
          return (
            <button
              class="card gallery-card"
              data-images={imagesJson}
              data-title={event.title}
              data-title-ko={event.titleKo}
            >
              <div class="gallery-thumb">
                <img src={withBase(thumb)} alt={event.title} loading="lazy" />
                {event.images.length > 1 && (
                  <span class="gallery-count">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                    {event.images.length}
                  </span>
                )}
              </div>
              <div class="gallery-info">
                <h3>{event.title}</h3>
                <p class="gallery-title-ko">{event.titleKo}</p>
                <time class="gallery-date" datetime={event.date}>
                  {new Date(event.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
            </button>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" hidden>
    <button class="lb-close" aria-label="Close">&times;</button>
    <button class="lb-prev" aria-label="Previous">&#8249;</button>
    <div class="lb-stage">
      <img id="lb-image" src="" alt="" />
      <div class="lb-caption">
        <span id="lb-title"></span>
        <span id="lb-counter"></span>
      </div>
    </div>
    <button class="lb-next" aria-label="Next">&#8250;</button>
  </div>
</BaseLayout>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .gallery-card {
    padding: 0;
    overflow: hidden;
    border: 1px solid var(--color-border);
    text-align: left;
    cursor: pointer;
    background: var(--color-bg-card);
    font: inherit;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  }

  .gallery-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--color-primary) 25%, var(--color-border));
  }

  .gallery-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .gallery-card:hover .gallery-thumb img {
    transform: scale(1.05);
  }

  .gallery-count {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 8px;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .gallery-info {
    padding: var(--space-4);
  }

  .gallery-info h3 {
    font-size: var(--text-base);
    margin-bottom: var(--space-1);
  }

  .gallery-title-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .gallery-date {
    font-size: var(--text-xs);
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.9);
    padding: var(--space-4);
  }

  .lightbox[hidden] {
    display: none;
  }

  .lb-stage {
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  #lb-image {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  .lb-caption {
    color: #fff;
    display: flex;
    gap: var(--space-3);
    align-items: baseline;
    font-size: var(--text-sm);
  }

  #lb-counter {
    color: rgba(255, 255, 255, 0.6);
  }

  .lb-close,
  .lb-prev,
  .lb-next {
    position: absolute;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.15s ease;
  }

  .lb-close:hover,
  .lb-prev:hover,
  .lb-next:hover {
    background: rgba(255, 255, 255, 0.28);
  }

  .lb-close {
    top: var(--space-4);
    right: var(--space-4);
    width: 44px;
    height: 44px;
    font-size: 28px;
    line-height: 1;
  }

  .lb-prev,
  .lb-next {
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    font-size: 34px;
    line-height: 1;
  }

  .lb-prev { left: var(--space-4); }
  .lb-next { right: var(--space-4); }

  @media (max-width: 768px) {
    .lb-prev, .lb-next { width: 42px; height: 42px; font-size: 26px; }
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox') as HTMLElement;
  const lbImage = document.getElementById('lb-image') as HTMLImageElement;
  const lbTitle = document.getElementById('lb-title') as HTMLElement;
  const lbCounter = document.getElementById('lb-counter') as HTMLElement;
  const btnClose = lightbox.querySelector('.lb-close') as HTMLButtonElement;
  const btnPrev = lightbox.querySelector('.lb-prev') as HTMLButtonElement;
  const btnNext = lightbox.querySelector('.lb-next') as HTMLButtonElement;

  let images: string[] = [];
  let title = '';
  let index = 0;

  function render() {
    lbImage.src = images[index];
    lbImage.alt = `${title} (${index + 1})`;
    lbTitle.textContent = title;
    lbCounter.textContent = images.length > 1 ? `${index + 1} / ${images.length}` : '';
    btnPrev.style.display = images.length > 1 ? '' : 'none';
    btnNext.style.display = images.length > 1 ? '' : 'none';
  }

  function open(imgs: string[], t: string) {
    images = imgs;
    title = t;
    index = 0;
    render();
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
  }

  function move(delta: number) {
    index = (index + delta + images.length) % images.length;
    render();
  }

  document.querySelectorAll<HTMLButtonElement>('.gallery-card').forEach((card) => {
    card.addEventListener('click', () => {
      try {
        const imgs = JSON.parse(card.dataset.images || '[]');
        open(imgs, card.dataset.title || '');
      } catch { /* noop */ }
    });
  });

  btnClose.addEventListener('click', close);
  btnPrev.addEventListener('click', () => move(-1));
  btnNext.addEventListener('click', () => move(1));
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });
  document.addEventListener('keydown', (e) => {
    if (lightbox.hidden) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowLeft') move(-1);
    else if (e.key === 'ArrowRight') move(1);
  });
</script>
