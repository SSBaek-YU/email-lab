---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { siteConfig } from '../data/site';
import { getPIInfo, getMembersByRole, getAlumni } from '../data/people';

const base = (import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/');
const pi = getPIInfo();
const postdocs = getMembersByRole('postdoc');
const phdStudents = getMembersByRole('phd');
const msPhd = getMembersByRole('ms-phd');
const msStudents = getMembersByRole('ms');
const undergrad = getMembersByRole('undergraduate');
const alumni = getAlumni();

const memberSections = [
  { title: 'Postdoctoral Researchers', titleKo: '박사후연구원', members: postdocs },
  { title: 'Ph.D. Students', titleKo: '박사과정', members: phdStudents },
  { title: 'Integrated M.S.–Ph.D. Students', titleKo: '석박사통합과정', members: msPhd },
  { title: 'M.S. Students', titleKo: '석사과정', members: msStudents },
  { title: 'Undergraduate Researchers', titleKo: '학부연구원', members: undergrad },
].filter((s) => s.members.length > 0);
---

<BaseLayout title="People" description="Members of the EMAIL Lab at Yeungnam University.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">People</h1>
      <p class="section-subtitle">Meet the members of {siteConfig.abbreviation}</p>

      {/* PI Section */}
      {pi && (
        <div class="pi-section">
          <h2>Principal Investigator</h2>
          <div class="pi-card">
            {pi.photo ? (
              <img src={`${base}${pi.photo.replace(/^\//, '')}`} alt={pi.name} class="pi-photo" loading="lazy" />
            ) : (
              <div class="pi-avatar" aria-hidden="true">{pi.name.charAt(0)}</div>
            )}
            <div class="pi-info">
              <h3>{pi.name}</h3>
              <p class="pi-name-ko">{pi.nameKo}</p>
              <p class="pi-role">{pi.roleLabel}</p>
              <p class="pi-dept">{siteConfig.department}, {siteConfig.university}</p>
              {pi.additionalInfo && (
                Array.isArray(pi.additionalInfo) ? (
                  <ul class="pi-additional-list">
                    {pi.additionalInfo.map((info) => <li>{info}</li>)}
                  </ul>
                ) : (
                  <p class="pi-additional">{pi.additionalInfo}</p>
                )
              )}
              <div class="pi-links">
                <SocialLinks
                  email={pi.email}
                  scholarUrl={pi.scholarUrl}
                  githubUrl={pi.githubUrl}
                  linkedinUrl={pi.linkedinUrl}
                  orcidUrl={pi.orcidUrl}
                  size="md"
                />
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Member Sections */}
      {memberSections.map((section) => (
        <div class="members-section">
          <h2>{section.title} <span class="title-ko">{section.titleKo}</span></h2>
          <div class="grid grid-3 members-grid">
            {section.members.map((member) => (
              <div class="card member-card">
                {member.photo ? (
                  <img
                    src={`${base}${member.photo.replace(/^\//, '')}`}
                    alt={member.name}
                    class="member-photo"
                    loading="lazy"
                  />
                ) : (
                  <div class="member-avatar" aria-hidden="true">
                    {member.name.charAt(0)}
                  </div>
                )}
                <h4>{member.name}</h4>
                {member.nameKo && <p class="member-name-ko">{member.nameKo}</p>}
                <p class="member-period">{member.period}</p>
                <div class="member-social">
                  <SocialLinks
                    email={member.email}
                    scholarUrl={member.scholarUrl}
                    githubUrl={member.githubUrl}
                    linkedinUrl={member.linkedinUrl}
                    orcidUrl={member.orcidUrl}
                    align="center"
                  />
                </div>
              </div>
            ))}

          </div>
        </div>
      ))}

      {/* Who's Next */}
      <div class="members-section whos-next-section">
        <h2>Who's Next? <span class="title-ko">다음은 당신입니다</span></h2>
        <a href={`${base}openings/`} class="whos-next-banner">
          <img
            src={`${base}images/people/whos-next.gif`}
            alt="Join our lab"
            class="whos-next-img"
            loading="lazy"
          />
          <div class="whos-next-text">
            <h3>Join Our Lab!</h3>
            <p>We are actively recruiting motivated students and researchers.</p>
            <span class="btn btn-primary">View Open Positions</span>
          </div>
        </a>
      </div>

      {/* Alumni */}
      {alumni.length > 0 && (
        <div class="members-section">
          <h2>Alumni <span class="title-ko">졸업생</span></h2>
          <div class="alumni-list">
            {alumni.map((alum) => (
              <div class="alumni-item">
                <span class="alumni-name">{alum.name} {alum.nameKo && `(${alum.nameKo})`}</span>
                <span class="alumni-role">{alum.roleLabel}</span>
                <span class="alumni-period">{alum.period}</span>
                {alum.alumniInfo && <span class="alumni-info">{alum.alumniInfo}</span>}
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .pi-section {
    margin-bottom: var(--space-12);
  }

  .pi-section h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-primary-bg);
  }

  .pi-card {
    display: flex;
    gap: var(--space-8);
    padding: var(--space-8);
    background: var(--color-bg-alt);
    border-radius: var(--radius-lg);
  }

  .pi-photo {
    width: 160px;
    height: 160px;
    min-width: 160px;
    border-radius: var(--radius-lg);
    object-fit: cover;
  }

  .pi-avatar {
    width: 160px;
    height: 160px;
    min-width: 160px;
    border-radius: var(--radius-lg);
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-4xl);
    font-weight: 800;
  }

  .pi-info h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
  }

  .pi-name-ko {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .pi-role {
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .pi-dept {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-2);
  }

  .pi-additional {
    font-size: var(--text-sm);
    color: var(--color-secondary);
    font-weight: 500;
    margin-bottom: var(--space-4);
  }

  .pi-additional-list {
    list-style: none;
    margin-bottom: var(--space-4);
  }

  .pi-additional-list li {
    font-size: var(--text-sm);
    color: var(--color-secondary);
    font-weight: 500;
    padding: var(--space-1) 0;
    padding-left: var(--space-4);
    position: relative;
  }

  .pi-additional-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-secondary);
  }

  .pi-links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .members-section {
    margin-bottom: var(--space-12);
  }

  .members-section h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-primary-bg);
  }

  .title-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .member-card {
    text-align: center;
    padding: var(--space-6);
  }

  .member-photo {
    width: 120px;
    height: 120px;
    border-radius: var(--radius-full);
    object-fit: cover;
    margin: 0 auto var(--space-4);
  }

  .member-avatar {
    width: 120px;
    height: 120px;
    border-radius: var(--radius-full);
    background: var(--color-primary-bg);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-3xl);
    font-weight: 700;
    margin: 0 auto var(--space-4);
  }

  .member-card h4 {
    margin-bottom: var(--space-1);
  }

  .member-name-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .member-period {
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  .member-social {
    margin-top: var(--space-3);
  }

  /* Who's Next Banner */
  .whos-next-banner {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding: var(--space-8);
    background: var(--color-bg-alt);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--transition);
  }

  .whos-next-banner:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-bg);
    box-shadow: var(--shadow-md);
  }

  .whos-next-img {
    width: 160px;
    height: 160px;
    min-width: 160px;
    border-radius: var(--radius-lg);
    object-fit: cover;
    background: var(--color-bg);
  }

  .whos-next-text h3 {
    font-size: var(--text-2xl);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .whos-next-text p {
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
  }

  @media (max-width: 768px) {
    .whos-next-banner {
      flex-direction: column;
      text-align: center;
    }
  }

  /* Alumni */
  .alumni-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .alumni-item {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    flex-wrap: wrap;
  }

  .alumni-name {
    font-weight: 600;
    min-width: 200px;
  }

  .alumni-role {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    min-width: 150px;
  }

  .alumni-period {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .alumni-info {
    font-size: var(--text-sm);
    color: var(--color-secondary);
  }

  @media (max-width: 768px) {
    .pi-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .pi-links {
      justify-content: center;
    }
  }
</style>
