---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
import { getPIInfo, getMembersByRole, getAlumni } from '../data/people';

const pi = getPIInfo();
const postdocs = getMembersByRole('postdoc');
const phdStudents = getMembersByRole('phd');
const msPhd = getMembersByRole('ms-phd');
const msStudents = getMembersByRole('ms');
const undergrad = getMembersByRole('undergraduate');
const alumni = getAlumni();

const memberSections = [
  { title: 'Postdoctoral Researchers', titleKo: '박사후연구원', members: postdocs },
  { title: 'Ph.D. Students', titleKo: '박사과정', members: phdStudents },
  { title: 'Integrated M.S.–Ph.D. Students', titleKo: '석박사통합과정', members: msPhd },
  { title: 'M.S. Students', titleKo: '석사과정', members: msStudents },
  { title: 'Undergraduate Researchers', titleKo: '학부연구원', members: undergrad },
].filter((s) => s.members.length > 0);
---

<BaseLayout title="People" description="Members of the EMAIL Lab at Yeungnam University.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">People</h1>
      <p class="section-subtitle">Meet the members of {siteConfig.abbreviation}</p>

      {/* PI Section */}
      {pi && (
        <div class="pi-section">
          <h2>Principal Investigator</h2>
          <div class="pi-card">
            <div class="pi-avatar" aria-hidden="true">{pi.name.charAt(0)}</div>
            <div class="pi-info">
              <h3>{pi.name}</h3>
              <p class="pi-name-ko">{pi.nameKo}</p>
              <p class="pi-role">{pi.roleLabel}</p>
              <p class="pi-dept">{siteConfig.department}, {siteConfig.university}</p>
              {pi.additionalInfo && <p class="pi-additional">{pi.additionalInfo}</p>}
              {pi.researchInterests && (
                <div class="pi-interests">
                  <h4>Research Interests</h4>
                  <div class="tag-list">
                    {pi.researchInterests.map((interest) => (
                      <span class="tag">{interest}</span>
                    ))}
                  </div>
                </div>
              )}
              <div class="pi-links">
                {pi.email && (
                  <a href={`mailto:${pi.email}`} class="btn btn-sm btn-outline">
                    Email
                  </a>
                )}
                {pi.scholarUrl && (
                  <a href={pi.scholarUrl} target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 9a8 8 0 0 1 7.162 4.44L24 9.5z"/>
                    </svg>
                    Google Scholar
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Member Sections */}
      {memberSections.map((section) => (
        <div class="members-section">
          <h2>{section.title} <span class="title-ko">{section.titleKo}</span></h2>
          <div class="grid grid-3 members-grid">
            {section.members.map((member) => (
              <div class="card member-card">
                <div class="member-avatar" aria-hidden="true">
                  {member.name.charAt(0)}
                </div>
                <h4>{member.name}</h4>
                {member.nameKo && <p class="member-name-ko">{member.nameKo}</p>}
                <p class="member-period">{member.period}</p>
                {member.email && (
                  <a href={`mailto:${member.email}`} class="member-email">{member.email}</a>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}

      {/* Alumni */}
      {alumni.length > 0 && (
        <div class="members-section">
          <h2>Alumni <span class="title-ko">졸업생</span></h2>
          <div class="alumni-list">
            {alumni.map((alum) => (
              <div class="alumni-item">
                <span class="alumni-name">{alum.name} {alum.nameKo && `(${alum.nameKo})`}</span>
                <span class="alumni-role">{alum.roleLabel}</span>
                <span class="alumni-period">{alum.period}</span>
                {alum.alumniInfo && <span class="alumni-info">{alum.alumniInfo}</span>}
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .pi-section {
    margin-bottom: var(--space-12);
  }

  .pi-section h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-primary-bg);
  }

  .pi-card {
    display: flex;
    gap: var(--space-8);
    padding: var(--space-8);
    background: var(--color-bg-alt);
    border-radius: var(--radius-lg);
  }

  .pi-avatar {
    width: 120px;
    height: 120px;
    min-width: 120px;
    border-radius: var(--radius-lg);
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-4xl);
    font-weight: 800;
  }

  .pi-info h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
  }

  .pi-name-ko {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .pi-role {
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .pi-dept {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-2);
  }

  .pi-additional {
    font-size: var(--text-sm);
    color: var(--color-secondary);
    font-weight: 500;
    margin-bottom: var(--space-4);
  }

  .pi-interests {
    margin-bottom: var(--space-4);
  }

  .pi-interests h4 {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .pi-links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .members-section {
    margin-bottom: var(--space-12);
  }

  .members-section h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-primary-bg);
  }

  .title-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .member-card {
    text-align: center;
    padding: var(--space-6);
  }

  .member-avatar {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-full);
    background: var(--color-primary-bg);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-2xl);
    font-weight: 700;
    margin: 0 auto var(--space-3);
  }

  .member-card h4 {
    margin-bottom: var(--space-1);
  }

  .member-name-ko {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .member-period {
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  .member-email {
    font-size: var(--text-sm);
    display: block;
    margin-top: var(--space-2);
  }

  .alumni-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .alumni-item {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    flex-wrap: wrap;
  }

  .alumni-name {
    font-weight: 600;
    min-width: 200px;
  }

  .alumni-role {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    min-width: 150px;
  }

  .alumni-period {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .alumni-info {
    font-size: var(--text-sm);
    color: var(--color-secondary);
  }

  @media (max-width: 768px) {
    .pi-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .pi-links,
    .tag-list {
      justify-content: center;
    }
  }
</style>
