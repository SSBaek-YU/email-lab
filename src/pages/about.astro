---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
import { awards } from '../data/awards';
---

<BaseLayout title="About" description="About the Environmental Monitoring/Modelling and AI Lab (EMAIL) at Yeungnam University.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">About {siteConfig.abbreviation}</h1>
      <p class="section-subtitle">{siteConfig.labNameKo}</p>

      <div class="about-content">
        <div class="about-intro">
          <p>
            The <strong>{siteConfig.labName} ({siteConfig.abbreviation})</strong> is a research group
            in the <strong>{siteConfig.department}</strong> at <strong>{siteConfig.university}</strong>,
            led by <strong>Prof. {siteConfig.professorName} ({siteConfig.professorNameKo})</strong>.
          </p>
          <p>
            EMAIL Lab investigates diverse environmental problems — water pollution, harmful algal blooms (HABs),
            and hydrological/hydraulic phenomena — through convergence technologies based on numerical
            analysis models and artificial intelligence (AI).
          </p>
          <p>
            We integrate satellite/drone imagery, in-situ observation data, and meteorological information
            to predict environmental data in real time, while enhancing reliability and interpretability
            through Explainable AI (XAI). Our research spans four core pillars: <strong>deep learning</strong>,
            <strong>modeling &amp; monitoring</strong>, <strong>visualization (AR/VR)</strong>,
            and <strong>eco-friendly semiconductor development</strong>.
          </p>
        </div>

        <div class="about-section">
          <h2>Research Vision</h2>
          <p>
            We pursue the integration of environmental numerical models with explainable artificial
            intelligence to advance our understanding of complex environmental systems. Our goal is
            to create reliable prediction and monitoring tools that support evidence-based environmental
            management and decision-making.
          </p>
        </div>

        <div class="about-section">
          <h2>Research Pillars</h2>
          <div class="grid grid-2 values-grid">
            <div class="card value-card">
              <h3>Deep Learning</h3>
              <p>Explainable AI, multimodal AI, GNN, and reinforcement learning for environmental prediction and decision support.</p>
            </div>
            <div class="card value-card">
              <h3>Modeling & Monitoring</h3>
              <p>Numerical simulation (SWMM, EFDC, EPANET) integrated with satellite, drone, and in-situ sensors for real-time environmental monitoring.</p>
            </div>
            <div class="card value-card">
              <h3>Visualization (AR/VR)</h3>
              <p>Immersive augmented reality and virtual reality applications for environmental simulation, flood risk assessment, and infrastructure management.</p>
            </div>
            <div class="card value-card">
              <h3>Eco-friendly Semiconductor</h3>
              <p>Memristor-based neuromorphic computing for energy-efficient environmental AI systems and low-power water quality prediction.</p>
            </div>
          </div>
        </div>

        <div class="about-section">
          <h2>Honors & Awards</h2>
          <div class="awards-list">
            {awards.map((award) => (
              <div class="award-item">
                {award.year ? <span class="award-year">{award.year}</span> : <span class="award-year"></span>}
                <div>
                  <h4>{award.title}</h4>
                  <p>{award.organization}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="about-section">
          <h2>Collaborating Organizations</h2>
          <ul class="collab-list">
            {siteConfig.collaborators.map((org) => (
              <li>{org}</li>
            ))}
          </ul>
        </div>

        <div class="about-section">
          <h2>Affiliation</h2>
          <p>
            <strong>{siteConfig.department}</strong><br />
            <a href={siteConfig.universityUrl} target="_blank" rel="noopener noreferrer">{siteConfig.university}</a><br />
            {siteConfig.address}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-content {
    max-width: 800px;
  }

  .about-intro {
    font-size: var(--text-lg);
    margin-bottom: var(--space-8);
  }

  .about-intro p {
    margin-bottom: var(--space-4);
  }

  .about-section {
    margin-bottom: var(--space-8);
  }

  .about-section h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-primary-bg);
  }

  .about-section p {
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .collab-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    padding-left: 0;
  }

  .collab-list li {
    list-style: none;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .collab-list {
      grid-template-columns: 1fr;
    }
  }

  .value-card {
    text-align: center;
  }

  .value-card h3 {
    font-size: var(--text-lg);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .value-card p {
    font-size: var(--text-sm);
  }

  .awards-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .award-item {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .award-year {
    font-weight: 700;
    color: var(--color-primary);
    min-width: 50px;
  }

  .award-item h4 {
    font-size: var(--text-base);
    margin-bottom: var(--space-1);
  }

  .award-item p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .values-grid {
    margin-top: var(--space-4);
  }
</style>
