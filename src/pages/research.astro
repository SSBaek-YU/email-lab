---
import BaseLayout from '../layouts/BaseLayout.astro';
import { researchAreas } from '../data/research';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<BaseLayout title="Research" description="Research areas of the EMAIL Lab including water quality modeling, environmental AI, remote sensing, and digital twin technologies.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Research</h1>

      <div class="research-list">
        {researchAreas.map((area, i) => (
          <article class="research-area" id={area.id}>
            <div class="research-header">
              <span class="research-num">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h2>{area.title}</h2>
                <p class="research-title-ko">{area.titleKo}</p>
              </div>
            </div>
            {area.image && (
              <div class="research-images">
                <img
                  src={`${base}${area.image.replace(/^\//, '')}`}
                  alt={area.title}
                  class="research-img"
                  loading="lazy"
                />
                {area.image2 && (
                  <img
                    src={`${base}${area.image2.replace(/^\//, '')}`}
                    alt={`${area.title} - additional`}
                    class="research-img"
                    loading="lazy"
                  />
                )}
              </div>
            )}
            <p class="research-desc">{area.description}</p>
            <p class="research-desc-ko">{area.descriptionKo}</p>
            <div class="research-details">
              <div class="research-detail">
                <h4>Methods</h4>
                <div class="tag-list">
                  {area.methods.map((m) => <span class="tag">{m}</span>)}
                </div>
              </div>
              <div class="research-detail">
                <h4>Applications</h4>
                <div class="tag-list">
                  {area.applications.map((a) => <span class="tag tag-green">{a}</span>)}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .research-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .research-area {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    transition: box-shadow var(--transition);
  }

  .research-area:hover {
    box-shadow: var(--shadow-md);
  }

  .research-header {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    margin-bottom: var(--space-4);
  }

  .research-num {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-primary-bg);
    line-height: 1;
    min-width: 48px;
  }

  .research-header h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
  }

  .research-title-ko {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .research-images {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .research-img {
    width: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-light);
  }

  .research-desc {
    color: var(--color-text-light);
    margin-bottom: var(--space-2);
    line-height: 1.8;
  }

  .research-desc-ko {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
  }

  .research-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .research-detail h4 {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: var(--space-3);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag-green {
    background: #e8f5e9;
    color: var(--color-secondary);
  }

  @media (max-width: 768px) {
    .research-area {
      padding: var(--space-6);
    }

    .research-details {
      grid-template-columns: 1fr;
    }

    .research-header {
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
