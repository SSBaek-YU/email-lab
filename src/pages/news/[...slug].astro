---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('news', ({ data }) => !data.draft);
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const base = (import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/');

const categoryLabels: Record<string, string> = {
  announcement: 'Announcement',
  publication: 'Publication',
  award: 'Award',
  event: 'Event',
  people: 'People',
};
---

<BaseLayout title={item.data.title} description={item.data.summary ?? item.data.title}>
  <section class="section">
    <div class="container">
      <a href={`${base}news/`} class="back-link">&larr; Back to News</a>

      <article class="news-article">
        <div class="news-meta">
          <span class={`news-badge badge-${item.data.category}`}>
            {categoryLabels[item.data.category] ?? item.data.category}
          </span>
          <time datetime={item.data.date.toISOString()}>
            {item.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>

        <h1 class="article-title">{item.data.title}</h1>
        {item.data.titleKo && <p class="article-title-ko">{item.data.titleKo}</p>}

        <div class="article-body">
          <Content />
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .news-article {
    max-width: 720px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-primary, #2563eb);
  }

  .news-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-light);
  }

  .news-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: var(--radius-full, 999px);
    font-weight: 600;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
  }

  .badge-award { background: #fef3c7; color: #92400e; }
  .badge-publication { background: #dbeafe; color: #1e40af; }
  .badge-event { background: #dcfce7; color: #166534; }
  .badge-people { background: #f3e8ff; color: #6b21a8; }

  .article-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
    line-height: 1.3;
  }

  .article-title-ko {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .article-body {
    line-height: 1.8;
    color: var(--color-text);
  }

  .article-body :global(p) {
    margin-bottom: var(--space-4);
  }

  .article-body :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }
</style>
