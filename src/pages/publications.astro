---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
import { getInternationalPubs, getDomesticPubs, getYears } from '../data/publications';
import { researchAreas } from '../data/research';
import scholar from '../data/scholar.json';

const intlPubs = getInternationalPubs();
const domesticPubs = getDomesticPubs();
const years = getYears('international');
const areas = researchAreas;
---

<BaseLayout title="Publications" description="Publications from the EMAIL Lab - peer-reviewed journal articles in environmental engineering, AI, and water quality modeling.">
  <section class="section">
    <div class="container">
      <div class="pub-header">
        <div>
          <h1 class="section-title">Publications</h1>
          <p class="section-subtitle">{intlPubs.length + domesticPubs.length} peer-reviewed publications</p>
        </div>
        <a
          href={siteConfig.scholarUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 9a8 8 0 0 1 7.162 4.44L24 9.5z"/>
          </svg>
          Google Scholar
        </a>
      </div>

      {scholar.hIndex != null && (
        <div class="scholar-stats">
          <a class="stat" href={siteConfig.scholarUrl} target="_blank" rel="noopener noreferrer">
            <span class="stat-num">{scholar.totalCitations?.toLocaleString()}</span>
            <span class="stat-label">Citations</span>
          </a>
          <a class="stat" href={siteConfig.scholarUrl} target="_blank" rel="noopener noreferrer">
            <span class="stat-num">{scholar.hIndex}</span>
            <span class="stat-label">h-index</span>
          </a>
          <a class="stat" href={siteConfig.scholarUrl} target="_blank" rel="noopener noreferrer">
            <span class="stat-num">{scholar.i10Index}</span>
            <span class="stat-label">i10-index</span>
          </a>
          {scholar.updatedAt && (
            <p class="stat-updated">
              Source: Google Scholar · updated {scholar.updatedAt}
            </p>
          )}
        </div>
      )}

      <!-- SCI / International Journal Publications -->
      <div class="pub-section">
        <h2 class="pub-section-title">International Journal Publications</h2>
        <p class="pub-section-count">{intlPubs.length} articles</p>

        <!-- Filters -->
        <div class="filters" id="filters">
          <div class="filter-group">
            <label for="search-input">Search</label>
            <input
              type="text"
              id="search-input"
              placeholder="Search by title or author..."
              class="filter-input"
            />
          </div>
          <div class="filter-group">
            <label for="year-filter">Year</label>
            <select id="year-filter" class="filter-select">
              <option value="">All Years</option>
              {years.map((y) => (
                <option value={String(y)}>{y}</option>
              ))}
            </select>
          </div>
          <div class="filter-group">
            <label for="area-filter">Research Area</label>
            <select id="area-filter" class="filter-select">
              <option value="">All Areas</option>
              {areas.map((a) => (
                <option value={a.id}>{a.title}</option>
              ))}
            </select>
          </div>
        </div>

        <div class="pub-list" id="pub-list-intl">
          {intlPubs.map((pub, i) => (
            <article
              class="pub-item"
              data-year={String(pub.year)}
              data-area={pub.researchArea || ''}
              data-search={`${pub.title.toLowerCase()} ${pub.authors.toLowerCase()}`}
            >
              <div class="pub-num">{intlPubs.length - i}</div>
              <div class="pub-content">
                <h3 class="pub-title">{pub.title}</h3>
                <p class="pub-authors">{pub.authors}</p>
                <p class="pub-journal">
                  <em>{pub.journal}</em>
                  {pub.volume && `, ${pub.volume}`}
                  {pub.issue && `(${pub.issue})`}
                  {pub.pages && `, ${pub.pages}`}
                  {pub.articleNumber && `, ${pub.articleNumber}`}
                  {' '}({pub.year})
                </p>
                <div class="pub-actions">
                  {pub.doi && (
                    <a
                      href={`https://doi.org/${pub.doi}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-sm btn-outline"
                    >
                      DOI
                    </a>
                  )}
                  {pub.authorRole === 'first' && (
                    <span class="tag tag-first">First Author</span>
                  )}
                  {pub.authorRole === 'corresponding' && (
                    <span class="tag tag-corresponding">Corresponding Author</span>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>

        <p class="pub-note" id="no-results" style="display:none;">
          No publications match your search criteria.
        </p>
      </div>

      <!-- Domestic Journal Publications -->
      {domesticPubs.length > 0 && (
        <div class="pub-section domestic-section">
          <h2 class="pub-section-title">Domestic Journal Publications</h2>
          <p class="pub-section-count">{domesticPubs.length} articles</p>

          <div class="pub-list" id="pub-list-domestic">
            {domesticPubs.map((pub, i) => (
              <article class="pub-item">
                <div class="pub-num">{domesticPubs.length - i}</div>
                <div class="pub-content">
                  <h3 class="pub-title">{pub.title}</h3>
                  <p class="pub-authors">{pub.authors}</p>
                  <p class="pub-journal">
                    <em>{pub.journal}</em>
                    {pub.volume && `, ${pub.volume}`}
                    {pub.issue && `(${pub.issue})`}
                    {pub.pages && `, ${pub.pages}`}
                    {' '}({pub.year})
                  </p>
                </div>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .pub-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .scholar-stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: stretch;
    margin-bottom: var(--space-10);
  }

  .scholar-stats .stat {
    flex: 1 1 140px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    padding: var(--space-5) var(--space-4);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition);
  }

  .scholar-stats .stat:hover {
    border-color: var(--color-primary-bg);
    box-shadow: var(--shadow-sm);
  }

  .stat-num {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .stat-updated {
    flex-basis: 100%;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin: 0;
  }

  .pub-section {
    margin-bottom: var(--space-12);
  }

  .pub-section-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-primary-bg);
  }

  .pub-section-count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .domestic-section .pub-section-title {
    border-bottom-color: #e8f5e9;
  }

  .filters {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .filter-group label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .filter-input,
  .filter-select {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-family: inherit;
    background: var(--color-bg);
    color: var(--color-text);
    min-width: 200px;
  }

  .filter-input:focus,
  .filter-select:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 1px;
    border-color: var(--color-primary);
  }

  .pub-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .pub-item {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-6);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    transition: all var(--transition);
  }

  .pub-item:hover {
    border-color: var(--color-primary-bg);
    box-shadow: var(--shadow-sm);
  }

  .pub-item.hidden {
    display: none;
  }

  .pub-num {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-primary);
    min-width: 36px;
    text-align: right;
    padding-top: 2px;
  }

  .pub-title {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-2);
    line-height: 1.5;
  }

  .pub-authors {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-1);
  }

  .pub-journal {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .pub-actions {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    align-items: center;
  }

  .tag-first {
    background: var(--color-primary-bg);
    color: var(--color-primary);
  }

  .tag-corresponding {
    background: #e8f5e9;
    color: var(--color-secondary);
  }

  .pub-note {
    text-align: center;
    color: var(--color-text-muted);
    padding: var(--space-8);
  }

  @media (max-width: 768px) {
    .pub-item {
      flex-direction: column;
      gap: var(--space-2);
    }

    .pub-num {
      text-align: left;
    }

    .filters {
      flex-direction: column;
    }

    .filter-input,
    .filter-select {
      min-width: 100%;
    }
  }
</style>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const yearFilter = document.getElementById('year-filter') as HTMLSelectElement;
  const areaFilter = document.getElementById('area-filter') as HTMLSelectElement;
  const pubItems = document.querySelectorAll('#pub-list-intl .pub-item') as NodeListOf<HTMLElement>;
  const noResults = document.getElementById('no-results') as HTMLElement;

  function filterPubs() {
    const search = searchInput.value.toLowerCase().trim();
    const year = yearFilter.value;
    const area = areaFilter.value;
    let visible = 0;

    pubItems.forEach((item) => {
      const itemYear = item.dataset.year || '';
      const itemArea = item.dataset.area || '';
      const itemSearch = item.dataset.search || '';

      const matchYear = !year || itemYear === year;
      const matchArea = !area || itemArea === area;
      const matchSearch = !search || itemSearch.includes(search);

      if (matchYear && matchArea && matchSearch) {
        item.classList.remove('hidden');
        visible++;
      } else {
        item.classList.add('hidden');
      }
    });

    noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  searchInput?.addEventListener('input', filterPubs);
  yearFilter?.addEventListener('change', filterPubs);
  areaFilter?.addEventListener('change', filterPubs);
</script>
